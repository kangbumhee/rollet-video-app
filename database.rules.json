{
  "rules": {
    "chat": {
      "$roomId": {
        "messages": {
          ".read": true,
          ".indexOn": ["timestamp"],
          "$messageId": {
            ".write": "auth != null",
            ".validate": "newData.hasChildren(['uid', 'displayName', 'text', 'timestamp']) && newData.child('text').isString() && newData.child('text').val().length <= 200"
          }
        }
      }
    },
    "rooms": {
      "$roomId": {
        "chat": {
          ".read": true,
          ".indexOn": ["timestamp"],
          "$messageId": {
            ".write": "auth != null",
            ".validate": "newData.hasChildren(['uid', 'displayName', 'message', 'timestamp']) && newData.child('message').isString() && newData.child('message').val().length <= 200"
          }
        },
        "presence": {
          ".read": true,
          "$uid": {
            ".write": "auth != null && auth.uid == $uid"
          }
        },
        "onlineCount": {
          ".read": true,
          ".write": "auth != null"
        },
        "autoGame": {
          ".read": true,
          ".write": "auth != null"
        },
        "state": {
          ".read": true,
          ".write": false
        },
        "tickets": {
          ".read": true,
          "$uid": {
            ".read": true,
            ".write": "auth != null && auth.uid == $uid"
          }
        }
      }
    },
    "cycle": {
      ".read": true,
      ".write": false
    },
    "games": {
      ".read": true,
      "$roomId": {
        "roundActions": {
          "$roundKey": {
            "$uid": {
              ".write": "auth != null && auth.uid === $uid",
              ".validate": "newData.hasChild('done') && newData.hasChild('score')"
            }
          }
        },
        "presence": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "drawing": {
          "$roundKey": {
            ".write": "auth != null",
            ".read": true
          }
        },
        "current": {
          ".write": false
        },
        "participants": {
          ".write": false
        },
        "rounds": {
          ".write": false
        }
      }
    },
    "miniGameRecords": {
      ".read": true,
      "$gameId": {
        ".write": "auth != null"
      }
    }
  }
}
